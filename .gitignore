# ====================================================================
# Visual Studio / MSBuild - Специфични файлове за компилация
# ====================================================================
# Папки с компилиран код (Output)
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bin/
bin-int/
# Междинни файлове от компилатора (Intermediate files)
*.obj
*.ilk
*.pdb
*.tlog
*.lastbuildstate
*.idb
*.pch
*.res
*.lnp
*.sbr
*.map

# ====================================================================
# Visual Studio - Потребителски настройки и кеш (Локални данни)
# ====================================================================
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# ====================================================================
# Резултати от статичен анализ и тестове
# ====================================================================
VisualStudioStudio/
*.code-workspace
.vs-codeanalysis/

# ====================================================================
# Зависимости и външни пакети (ако ползваш vcpkg / NuGet)
# ====================================================================
vcpkg_installed/
.vcpkg/
packages/
*.nuget.props
*.nuget.targets

# ====================================================================
# Общи системни файлове
# ====================================================================
.DS_Store
Thumbs.db
